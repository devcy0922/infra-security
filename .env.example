# =============================================================
# infra-security — 환경 변수 설정 예시
# .env.example → .env 복사 후 값 수정
# =============================================================

# ----- 공통 -----
COMPOSE_PROJECT_NAME=infra-security

# Keycloak 접근 호스트명 (Nginx가 바라보는 도메인 또는 IP)
KC_HOSTNAME=<YOUR_HOST_OR_DOMAIN>

# ----- MariaDB (레거시 앱용 DB) -----
MARIADB_ROOT_PASSWORD=<CHANGE_ME>
MARIADB_DATABASE=appdb
MARIADB_USER=appuser
MARIADB_PASSWORD=<CHANGE_ME>
MARIADB_READER_PASSWORD=<CHANGE_ME>

# ----- MariaDB (Keycloak 전용 DB) -----
KC_DB_HOST=mariadb-kc
KC_DB_PORT=3306
KC_DB_DATABASE=keycloakdb
KC_DB_USER=kcuser
KC_DB_PASSWORD=<CHANGE_ME>

# ----- Legacy DB — Custom SPI 연결 (Lazy Migration 대상) -----
# ProxySQL 경유 or 직접 Writer 연결
LEGACY_DB_URL=jdbc:mariadb://mariadb-writer:3306/appdb
LEGACY_DB_USER=appuser
LEGACY_DB_PASS=<CHANGE_ME>

# ----- ProxySQL -----
PROXYSQL_ADMIN_USER=radmin
PROXYSQL_ADMIN_PASS=<CHANGE_ME>
PROXYSQL_MONITOR_USER=monitor
PROXYSQL_MONITOR_PASS=<CHANGE_ME>

# ----- Keycloak -----
KC_ADMIN=admin
KC_ADMIN_PASSWORD=<CHANGE_ME>
# Infinispan 클러스터링 포트 (컨테이너 내부 통신용, 변경 불필요)
KC_JGROUPS_PORT=7800

# ----- Token 보안 설정 -----
KC_ACCESS_TOKEN_LIFESPAN=300        # 5분 (초 단위)
KC_SSO_SESSION_MAX_LIFESPAN=1800    # 30분
KC_REFRESH_TOKEN_ROTATION=true

# ----- TLS (Nginx → Keycloak 앞단) -----
# 개발: ./scripts/gen-certs.sh 로 self-signed 생성
TLS_CERT_PATH=./nginx/certs/server.crt
TLS_KEY_PATH=./nginx/certs/server.key

# =============================================================
# 기존 ai-service-infra 모니터링 스택 연동 설정
# Prometheus, Grafana, Loki, Promtail 은 해당 스택을 공유함
# =============================================================

# ai-service-infra Docker 네트워크 이름 (docker network ls 로 확인)
# 기본값: ai-service-infra_monitoring
INFRA_MONITORING_NETWORK=ai-service-infra_monitoring

# 기존 Prometheus 서버 주소 (스크랩 타겟 추가 시 사용)
PROMETHEUS_HOST=<YOUR_PROMETHEUS_HOST>
PROMETHEUS_PORT=9090

# 기존 Loki 서버 주소 (Promtail push 대상)
LOKI_HOST=<YOUR_LOKI_HOST>
LOKI_PORT=3100

# 기존 Grafana 주소 (대시보드 Import 대상)
GRAFANA_HOST=<YOUR_GRAFANA_HOST>
GRAFANA_PORT=3000
