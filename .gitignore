.gitignore generated by infra-security

# 환경변수 (절대 커밋 금지)
.env

# TLS 인증서
nginx/certs/*.crt
nginx/certs/*.key
nginx/certs/*.pem

# ProxySQL 런타임 데이터 및 로그
proxysql/logs/*.log
proxysql/logs/*.log.*

# Keycloak SPI 빌드 산출물
keycloak/providers/custom-user-spi/target/
keycloak/providers/custom-user-spi/.mvn/
*.jar

# Java 빌드
*.class
*.war

# macOS
.DS_Store
.AppleDouble

# IDE
.idea/
*.iml
.vscode/
*.swp

# Docker 임시 파일
docker-compose.override.yml
