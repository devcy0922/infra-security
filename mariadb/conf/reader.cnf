[mysqld]
# Reader 전용 튜닝 — 읽기 최적화
server_id          = 2
read_only          = ON              # 실수 Write 방지
log_bin            = OFF

# InnoDB 튜닝 (읽기 중심 — 버퍼 풀 크게)
innodb_buffer_pool_size   = 768M
innodb_flush_log_at_trx_commit = 2   # 성능 우선 (Reader는 복구 허용)
innodb_flush_method        = O_DIRECT
innodb_file_per_table      = ON

# 연결 설정
max_connections    = 400             # Reader 더 많은 연결 허용
wait_timeout       = 600

# 슬로우 쿼리 로그
slow_query_log         = 1
slow_query_log_file    = /var/log/mysql/slow.log
long_query_time        = 2

# 문자셋
character_set_server = utf8mb4
collation_server     = utf8mb4_unicode_ci
